generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoomStatus {
  LOBBY
  ACTIVE
  SUMMARY
  DESTROYED
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  FINISHED
  ABANDONED
}

enum TeamSide {
  A
  B
}

enum SeatStatus {
  OPEN
  OCCUPIED
  DISCONNECTED
  REPLACED
}

enum AnalyticsEventType {
  ROOM_CREATED
  MATCH_STARTED
  MATCH_FINISHED
  RECONNECT_SUCCESS
  SEAT_REPLACED
}

model Room {
  id             String              @id @default(cuid())
  code           String              @unique
  status         RoomStatus          @default(LOBBY)
  hostSeatId     String?
  maxPlayers     Int
  targetScore    Int
  allowBongs     Boolean             @default(true)
  allow3v3       Boolean             @default(false)
  currentMatchId String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  matches        Match[]
  seats          RoomSeat[]
  snapshots      MatchSnapshot[]
  actionLogs     ActionLog[]
  analytics      AnalyticsEvent[]
}

model RoomSeat {
  id           String          @id @default(cuid())
  roomId       String
  seatIndex    Int
  teamSide     TeamSide?
  status       SeatStatus      @default(OPEN)
  displayName  String?
  avatarSeed   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  room         Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  occupancies  SeatOccupancy[]

  @@unique([roomId, seatIndex])
}

model SeatOccupancy {
  id                String     @id @default(cuid())
  roomSeatId        String
  guestPlayerId     String
  roomSessionToken  String     @unique
  seatClaimToken    String     @unique
  isCurrent         Boolean    @default(true)
  joinedAt          DateTime   @default(now())
  releasedAt        DateTime?
  roomSeat          RoomSeat   @relation(fields: [roomSeatId], references: [id], onDelete: Cascade)
  connections       ConnectionSession[]
}

model Match {
  id               String          @id @default(cuid())
  roomId           String
  status           MatchStatus     @default(PENDING)
  winnerTeamSide   TeamSide?
  effectiveBongs   Int             @default(0)
  finalScore       Json?
  createdAt        DateTime        @default(now())
  startedAt        DateTime?
  finishedAt       DateTime?
  room             Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  snapshots        MatchSnapshot[]
  actionLogs       ActionLog[]
}

model MatchSnapshot {
  id          String    @id @default(cuid())
  roomId       String
  matchId      String?
  version      Int
  state        Json
  createdAt    DateTime  @default(now())
  room         Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  match        Match?    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([roomId, version])
}

model ActionLog {
  id                 String    @id @default(cuid())
  roomId             String
  matchId            String?
  seatId             String?
  occupancyId        String?
  actionType         String
  payload            Json
  effectiveBongAward Boolean   @default(false)
  createdAt          DateTime  @default(now())
  room               Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  match              Match?    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model ConnectionSession {
  id              String        @id @default(cuid())
  occupancyId     String
  socketId        String?
  reconnectToken  String        @unique
  connectedAt     DateTime      @default(now())
  disconnectedAt  DateTime?
  occupancy       SeatOccupancy @relation(fields: [occupancyId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  roomId      String?
  type        AnalyticsEventType
  payload     Json?
  createdAt   DateTime          @default(now())
  room        Room?             @relation(fields: [roomId], references: [id], onDelete: SetNull)
}
